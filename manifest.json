{
  "manifest_version": 3,
  "name": "AI Mail Organizer",
  "version": "1.1",
  "description": "AI email organizer: categorize, summarize and group your Gmail with free AI. No API key needed.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "identity"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://text.pollinations.ai/*",
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "107718613632-ajvjm69is7r93bv5ifstt83q8b42ualn.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.modify"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Mail Organizer",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "app.js",
        "content.js"
      ],
      "matches": [
        "https://mail.google.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}